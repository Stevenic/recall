{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "./src",
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": false,
    "sourceMap": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": false,
    "resolveJsonModule": true,
    "types": ["node"],
    "lib": ["ES2023"]
  },
  "include": ["./src/**/*.ts"],
  "exclude": ["./dist/**", "./node_modules/**", "./tests/**"]
}
