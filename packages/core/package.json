{
  "name": "recall",
  "version": "0.1.0",
  "description": "Agent memory service with full lifecycle management",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "recall": "./dist/cli.js"
  },
