    "vectra": "^0.14.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
