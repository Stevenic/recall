source "https://rubygems.org"

# Jekyll + just-the-docs for the Recall + Recall Bench docs site.
# The pages.yml workflow installs these with bundler-cache.

gem "jekyll", "~> 4.3"
gem "just-the-docs", "~> 0.10"
gem "jekyll-seo-tag"

# Required platform glue
platforms :mingw, :x64_mingw, :mswin, :jruby do
  gem "tzinfo", ">= 1", "< 3"
  gem "tzinfo-data"
end

gem "wdm", "~> 0.2.0", :platforms => [:mingw, :x64_mingw, :mswin]

# HTTP client newer Ruby needs
gem "http_parser.rb", "~> 0.6.0", :platforms => [:jruby]
